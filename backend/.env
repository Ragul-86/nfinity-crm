# ─── SERVER ───────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ─── DATABASE ─────────────────────────────────────────────
MONGODB_URI=mongodb+srv://suganyanfinitypartner_db_user:Crmdashboard1234@crm-dashboard.iquh1su.mongodb.net/?appName=crm-dashboard

# ─── JWT ──────────────────────────────────────────────────
JWT_SECRET=jwtsceretkeycrm
JWT_REFRESH_SECRET=jwtrefreshsecretkeycrm
JWT_EXPIRE=7d
JWT_REFRESH_EXPIRE=30d

# ─── FRONTEND URL ─────────────────────────────────────────
CLIENT_URL=http://localhost:5173

# ─── EMAIL (Gmail SMTP) ───────────────────────────────────
# Gmail → Settings → Security → App Passwords → Generate
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your@gmail.com
EMAIL_PASS=your_gmail_app_password
EMAIL_FROM=NFINITY CRM <noreply@nfinity.com>

# ─── FILE UPLOAD ──────────────────────────────────────────
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=10485760

# ─── PLATFORM SUPER ADMIN ─────────────────────────────────
# Server start-ல் automatically create ஆகும் (one-time)
PLATFORM_ADMIN_NAME=Platform Admin
PLATFORM_ADMIN_EMAIL=platform@nfinity.com
PLATFORM_ADMIN_PASSWORD=Platform@1234

# ─── ENCRYPTION KEY ───────────────────────────────────────
# AI API keys DB-ல் encrypt பண்ண use ஆகும்
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=33415301d23e173f89cfccd916a7c5b769c9d7848aa4dc53484fc2ab837385d2

# ─── AI (Optional - Fallback Key) ────────────────────────
# Settings page-ல் per-tenant key add பண்ணலாம்
# இல்லன்னா இந்த env key fallback ஆ use ஆகும்
ANTHROPIC_API_KEY=

# ─── META / FACEBOOK LEAD ADS (Optional) ─────────────────
# Facebook Lead Ads webhook integrate பண்ண மட்டும் தேவை
META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret
META_PAGE_ACCESS_TOKEN=your_page_access_token
META_PAGE_ID=your_facebook_page_id
META_WEBHOOK_VERIFY_TOKEN=nfinity_webhook_verify_2024
